# IDE / OS
.DS_Store
.vscode/
.idea/

# Custom project files to ignore
pencil-new.pen

# Python (Backend)
**/__pycache__/
*.py[cod]
*$py.class
backend/venv/
backend/.venv/
backend/env/
backend/.env
backend/.env.*
backend/.pytest_cache/
*.sqlite3

# Environment Variables (Root level just in case)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node.js / Frontend (Though frontend/.gitignore takes precedence, fallback rules)
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase Local data
supabase/.temp/

# Solana / Anchor build artifacts (heavy, regeneratable)
target/
**/target/
.anchor/

# Market data caches (regeneratable)
backend/data/futures_cache/

# MCP / IDE local config
.serena/

# Accidental pip command output files (e.g. created by `pip install pkg=1.65.0` typo)
backend/=*
